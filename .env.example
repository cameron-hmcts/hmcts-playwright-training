# Test Login Credentials Example
# Copy this file to .env and fill in with your test credentials

# Password is the same for all test users
TEST_PASSWORD=secret_sauce

# Standard user credentials
TEST_USER_STANDARD=standard_user

# Error user credentials
TEST_USER_ERROR=error_user

# Locked out user credentials
TEST_USER_LOCKED_OUT=locked_out_user

# Performance glitch user credentials
TEST_USER_PERFORMANCE_GLITCH=performance_glitch_user

# Problem user credentials
TEST_USER_PROBLEM=problem_user

# Visual user credentials
TEST_USER_VISUAL=visual_user

# Application URL
TEST_BASE_URL=https://www.saucedemo.com/
